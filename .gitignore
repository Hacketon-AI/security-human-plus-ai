# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Secrets and credentials — never commit (see .claude/settings.json deny list)
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
secrets/
secret/
credentials/

# Sensitive security data — evidence, reports, raw scanner output
evidence/
scan-results/
scan-output/
*.sarif

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
dist/
build/
.coverage
htmlcov/

# Node / Next.js frontend
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*

# Local overrides
.claude/settings.local.json

# Log files
*.log
.kiro
# Ignore accidental literal Cursor folder
/~/.cursor/
