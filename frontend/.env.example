# SecureScope Frontend Configuration
# Copy this file to .env and adjust values for your local environment.

# Backend API base URL (used by the fetch client).
# When using Next.js rewrites (next.config.ts), set this to an empty string
# so requests go through the proxy: NEXT_PUBLIC_API_BASE_URL=
# Otherwise point to the backend directly: http://127.0.0.1:8000
NEXT_PUBLIC_API_BASE_URL=

# Default organization ID header sent on API requests.
# Backend uses this for tenant scoping (X-Organization-Id).
# In development, any UUID string works. Example:
# NEXT_PUBLIC_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEFAULT_ORG_ID=
