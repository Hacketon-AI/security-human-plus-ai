{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.keystore)",
      "Read(**/secrets/**)",
      "Read(**/secret/**)",
      "Read(**/credentials/**)",
      "Read(**/evidence/**)",
      "Read(**/scan-results/**)",
      "Read(**/scan-output/**)",
      "Read(**/*.sarif)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/secrets/**)",
      "Edit(**/evidence/**)",
      "Edit(**/scan-results/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/secrets/**)",
      "Write(**/evidence/**)",
      "Write(**/scan-results/**)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git clean:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(rm -rf:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(docker run:*)",
      "Bash(docker exec:*)"
    ]
  }
}
