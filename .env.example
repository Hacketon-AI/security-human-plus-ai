SECURESCOPE_ENVIRONMENT=development
SECURESCOPE_DATABASE_DSN=postgresql+asyncpg://user:pass@localhost:5432/db
# Required in staging/production: set a unique high-entropy value. Never commit it.
SECURESCOPE_JWT_SECRET=
# Optional first administrator. All four settings are required together, and the
# organization must already be provisioned. Do not use source-controlled values.
SECURESCOPE_BOOTSTRAP_ADMIN_EMAIL=agungzippo@legaltechz.com
SECURESCOPE_BOOTSTRAP_ADMIN_USERNAME=agungzippo
SECURESCOPE_BOOTSTRAP_ADMIN_PASSWORD=Agung140793@
SECURESCOPE_BOOTSTRAP_ADMIN_ORGANIZATION_ID=128099337829938917
SECURESCOPE_BOOTSTRAP_ADMIN_FULL_NAME=Administrator

SECURESCOPE_AI_PROOF_OF_RISK_ENABLED=true
SECURESCOPE_AI_ROUTER_MODE=hybrid
SECURESCOPE_AI_SANDBOX_SIMULATION_ENABLED=false

# ── Fireworks AI (live reasoning provider for this submission) ──
SECURESCOPE_FIREWORKS_API_KEY=
SECURESCOPE_FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
SECURESCOPE_FIREWORKS_MODEL_NAME=accounts/fireworks/models/gemma-4-31b-it
SECURESCOPE_AI_MAX_REMOTE_TOKENS=4000

# ── AMD ROCm Local Provider ──
# The local-amd-model-mock is a deterministic compatibility fallback.
# It does NOT perform real AMD GPU inference.
# When AMD Developer Cloud access is available, point BASE_URL to the
# real ROCm-served model and use the amd-rocm Docker Compose profile.
SECURESCOPE_AI_LOCAL_AMD_ENABLED=true
SECURESCOPE_AI_LOCAL_AMD_BASE_URL=http://local-amd-model-mock:8000/v1
SECURESCOPE_AI_LOCAL_AMD_MODEL_NAME=gemma-local-mock

# Frontend Variables
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK_API=false
API_INTERNAL_BASE_URL=http://securescope-api:8000

# Comma-separated org UUIDs used to bootstrap the multi-tenant dev workspace.
# Matches the three seed organizations created by `python -m app.seed`.
NEXT_PUBLIC_SEED_ORG_IDS=00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002,00000000-0000-0000-0000-000000000003
