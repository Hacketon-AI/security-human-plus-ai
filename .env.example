SECURESCOPE_FIREWORKS_MODEL_NAME=accounts/fireworks/models/gemma-2-9b-it
SECURESCOPE_AI_MAX_REMOTE_TOKENS=4000

# Frontend Variables
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCK_API=false
